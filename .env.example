# 필수
DATABASE_URL=postgres://user:pass@localhost:5432/adapter?sslmode=disable
KAFKA_BROKER=localhost:9092
REDIS_URL=redis://localhost:6379
BUNDLER_URL=http://localhost:3000

# 선택 (기본값 있음)
WS_LISTEN=:8080
DEPLOY_LOCK_TTL_MS=30000
# 로깅: 운영(ELK 수집)에서는 LOG_PRETTY=false → pino 포맷 JSON 출력
LOG_LEVEL=debug
LOG_PRETTY=true
